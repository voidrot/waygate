# Copy this file to .env.compose for Docker Compose based development or deployment.

# Application process settings
# HOST is passed through to containers but only used by the web process.
HOST = "0.0.0.0"
LOG_LEVEL = "INFO"

# Web app auth defaults for local Compose development.
WAYGATE_WEB_BASE_URL = "http://127.0.0.1:8080"
WAYGATE_WEB_SESSION_SECURE = "false"

# Compose-specific host bind mount settings
WIKI_DATA_DIR = "./wiki"

# Core runtime settings for containers
WAYGATE_CORE__STORAGE_PLUGIN_NAME = "local-storage"
WAYGATE_CORE__LLM_PLUGIN_NAME = "OllamaProvider"
WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME = "communication-nats"
WAYGATE_CORE__PG_HOST = "db"
WAYGATE_CORE__PG_PORT = "5432"
WAYGATE_CORE__PG_USER = "postgres"
WAYGATE_CORE__PG_PASSWORD = "postgres"
WAYGATE_CORE__PG_DB = "postgres"
WAYGATE_CORE__REDIS_DSN = "redis://valkey:6379/0"
WAYGATE_CORE__TEMPLATE_PACKAGES = "waygate_core"
WAYGATE_CORE__RAW_DOC_TEMPLATE = "raw_document.j2"
WAYGATE_CORE__COMPILED_DOC_TEMPLATE = "compiled_document.j2"
WAYGATE_CORE__PUBLISHED_DOC_TEMPLATE = "published_document.j2"
WAYGATE_CORE__METADATA_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__DRAFT_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__REVIEW_MODEL_NAME = "hermes3:8b"

# Optional JSON override for per-workflow model and option defaults.
# This value must be valid JSON.
# WAYGATE_CORE__LLM_WORKFLOW_PROFILES = '{"compile":{"model_name":"qwen3.5:9b","provider_options":{"OllamaProvider":{"num_ctx":4096}}}}'

# Backward-compatible aliases still accepted by the runtime.
# WAYGATE_CORE__REDIS_URL = "redis://valkey:6379/0"
# WAYGATE_CORE__RAW_DOCUMENT_TEMPLATE = "raw_document.j2"
# WAYGATE_CORE__COMPILED_DOCUMENT_TEMPLATE = "compiled_document.j2"
# WAYGATE_CORE__PUBLISHED_DOCUMENT_TEMPLATE = "published_document.j2"
# WAYGATE_CORE__METADATA_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__DRAFT_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__REVIEW_MODEL = "hermes3:8b"

# Local storage plugin
WAYGATE_LOCAL_STORAGE__FILE_PREFIX = "file://"
WAYGATE_LOCAL_STORAGE__BASE_PATH = "/data/wiki"
WAYGATE_LOCAL_STORAGE__RAW_DIR = "raw"
WAYGATE_LOCAL_STORAGE__STAGING_DIR = "staging"
WAYGATE_LOCAL_STORAGE__REVIEW_DIR = "review"
WAYGATE_LOCAL_STORAGE__PUBLISH_DIR = "published"
WAYGATE_LOCAL_STORAGE__METADATA_DIR = "metadata"
WAYGATE_LOCAL_STORAGE__TEMPLATES_DIR = "templates"
WAYGATE_LOCAL_STORAGE__AGENTS_DIR = "agents"
WAYGATE_LOCAL_STORAGE__SOFT_DELETE = "false"
WAYGATE_LOCAL_STORAGE__KEEP_VERSIONED = "false"

# communication-rq plugin
# Optional legacy transport. Switch WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME back
# to communication-rq if you need the Redis/RQ worker path.
WAYGATE_COMMUNICATION_RQ__REDIS_URL = "redis://valkey:6379/0"
WAYGATE_COMMUNICATION_RQ__DRAFT_QUEUE_NAME = "draft"
WAYGATE_COMMUNICATION_RQ__CRON_QUEUE_NAME = "cron"
WAYGATE_COMMUNICATION_RQ__JOB_FUNCTION = "waygate_workflows.draft.jobs.process_workflow_trigger"
WAYGATE_COMMUNICATION_RQ__JOB_TIMEOUT = "5m"
WAYGATE_COMMUNICATION_RQ__RESULT_TTL = "500"
WAYGATE_COMMUNICATION_RQ__FAILURE_TTL = "31536000"
WAYGATE_COMMUNICATION_RQ__RETRY_MAX = "3"
WAYGATE_COMMUNICATION_RQ__RETRY_INTERVALS = "[10, 30, 60]"
WAYGATE_COMMUNICATION_RQ__UNIQUE_JOBS = "true"

# communication-http plugin
# Use a container-reachable worker endpoint if you switch
# WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME to communication-http.
# WAYGATE_COMMUNICATION_HTTP__ENDPOINT = "http://worker:8090/workflows/trigger"
WAYGATE_COMMUNICATION_HTTP__TIMEOUT_SECONDS = "5.0"
WAYGATE_COMMUNICATION_HTTP__MAX_RETRIES = "2"
WAYGATE_COMMUNICATION_HTTP__RETRY_BACKOFF_SECONDS = "0.25"
# WAYGATE_COMMUNICATION_HTTP__AUTH_TOKEN = "replace-me"
WAYGATE_COMMUNICATION_HTTP__AUTH_HEADER = "Authorization"

# communication-nats plugin and worker
# Default Compose transport for durable workflow execution.
WAYGATE_COMMUNICATION_NATS__SERVERS = "nats://nats:4222"
WAYGATE_COMMUNICATION_NATS__STREAM_NAME = "WAYGATE_WORKFLOW"
WAYGATE_COMMUNICATION_NATS__DRAFT_SUBJECT = "waygate.workflow.draft"
WAYGATE_COMMUNICATION_NATS__CRON_SUBJECT = "waygate.workflow.cron"
WAYGATE_COMMUNICATION_NATS__CLIENT_NAME = "waygate-communication-nats"
WAYGATE_COMMUNICATION_NATS__CONNECT_TIMEOUT_SECONDS = "2.0"
WAYGATE_COMMUNICATION_NATS__PUBLISH_TIMEOUT_SECONDS = "5.0"

WAYGATE_WORKER__SERVERS = "nats://nats:4222"
WAYGATE_WORKER__STREAM_NAME = "WAYGATE_WORKFLOW"
WAYGATE_WORKER__DRAFT_SUBJECT = "waygate.workflow.draft"
WAYGATE_WORKER__CRON_SUBJECT = "waygate.workflow.cron"
WAYGATE_WORKER__DRAFT_CONSUMER_NAME = "waygate-draft"
WAYGATE_WORKER__CRON_CONSUMER_NAME = "waygate-cron"
WAYGATE_WORKER__CLIENT_NAME = "waygate-nats-worker"
WAYGATE_WORKER__ACK_WAIT_SECONDS = "30.0"
WAYGATE_WORKER__IN_PROGRESS_HEARTBEAT_SECONDS = "15.0"
WAYGATE_WORKER__MAX_DELIVER = "3"
WAYGATE_WORKER__BACKOFF_SECONDS = "[10, 30, 60]"

# Ollama provider plugin
WAYGATE_OLLAMAPROVIDER__BASE_URL = "http://ollama:11434"
WAYGATE_OLLAMAPROVIDER__VALIDATE_MODEL_ON_INIT = "true"

# Featherless AI provider plugin
# Uncomment these and switch WAYGATE_CORE__LLM_PLUGIN_NAME when using Featherless AI.
# WAYGATE_CORE__LLM_PLUGIN_NAME = "FeatherlessAIProvider"
# WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_API_KEY = "your-featherless-api-key"
WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_BASE_URL = "https://api.featherless.ai/v1"

# agent-session webhook plugin
# Provide a signing secret in production. For local-only unsigned testing, set
# ALLOW_UNSIGNED to true and leave SIGNING_SECRET commented out.
# WAYGATE_AGENT_SESSION__SIGNING_SECRET = "replace-me"
WAYGATE_AGENT_SESSION__ALLOW_UNSIGNED = "false"
WAYGATE_AGENT_SESSION__MAX_TIMESTAMP_SKEW_SECONDS = "300"

# Compose service image and port settings
POSTGRES_VERSION = "18"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "postgres"
POSTGRES_DB = "postgres"
PGDATA = "/var/lib/postgresql/data"
POSTGRES_PORT = "5432"

VALKEY_VERSION = "9"
VALKEY_PORT = "6379"

CHROMA_VERSION = "1.5.8"
CHROMA_PORT = "8000"
CHROMA_PERSIST_DIRECTORY = "/chroma/chroma"
CHROMA_TELEMETRY = "FALSE"

OLLAMA_VERSION = "0.21.0"
OLLAMA_PORT = "11434"
OLLAMA_KEEP_ALIVE = "5m"
OLLAMA_FLASH_ATTENTION = "1"
OLLAMA_KV_CACHE_TYPE = "q8_0"
GPU_DRIVER = "nvidia"
GPU_COUNT = "all"

NATS_VERSION = "2-alpine"
NATS_CLIENT_PORT = "4222"
NATS_MONITORING_PORT = "8222"
NATS_CLUSTER_PORT = "6222"
