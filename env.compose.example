# Copy this file to .env.compose for Docker Compose based development or deployment.

# Application process settings
# HOST is passed through to containers but only used by the web process.
HOST = "0.0.0.0"
LOG_LEVEL = "INFO"

# Web app auth defaults for local Compose development.
WAYGATE_WEB_AUTH__API_BASE_URL = "http://127.0.0.1:8080"
WAYGATE_WEB_AUTH__DEFAULT_DATABASE_URI = "postgresql+asyncpg://postgres:postgres@db:5432/postgres"
WAYGATE_WEB_AUTH__SESSION_SECURE = "false"

# Web app auth settings reference.
# Use only WAYGATE_WEB_AUTH__... variables. Bare AuthTuna env vars are ignored.
# Application
# WAYGATE_WEB_AUTH__APP_NAME = "WayGate"
# WAYGATE_WEB_AUTH__ALGORITHM = "HS256"
# WAYGATE_WEB_AUTH__TRY_FULL_INITIALIZE_WHEN_SYSTEM_USER_EXISTS_AGAIN = "false"

# Security
# WAYGATE_WEB_AUTH__JWT_SECRET_KEY = "replace-me"
# WAYGATE_WEB_AUTH__ENCRYPTION_PRIMARY_KEY = "replace-me"
# WAYGATE_WEB_AUTH__ENCRYPTION_SECONDARY_KEYS = '["old-encryption-key"]'
# WAYGATE_WEB_AUTH__FERNET_KEYS = '["base64-fernet-key"]'

# Feature flags
# WAYGATE_WEB_AUTH__MFA_ENABLED = "true"
# WAYGATE_WEB_AUTH__PASSKEYS_ENABLED = "true"
# WAYGATE_WEB_AUTH__UI_ENABLED = "true"
# WAYGATE_WEB_AUTH__ADMIN_ROUTES_ENABLED = "true"
# WAYGATE_WEB_AUTH__PASSWORDLESS_LOGIN_ENABLED = "true"
# WAYGATE_WEB_AUTH__ONLY_MIDDLEWARE = "false"

# Default users and roles
# WAYGATE_WEB_AUTH__DEFAULT_SUPERADMIN_PASSWORD = "replace-with-bootstrap-password"
# WAYGATE_WEB_AUTH__DEFAULT_ADMIN_PASSWORD = "replace-with-bootstrap-password"
# WAYGATE_WEB_AUTH__DEFAULT_SUPERADMIN_EMAIL = "superadmin@example.com"
# WAYGATE_WEB_AUTH__DEFAULT_ADMIN_EMAIL = "admin@example.com"

# Database
# WAYGATE_WEB_AUTH__DEFAULT_DATABASE_URI = "postgresql+asyncpg://postgres:postgres@db:5432/postgres"
# WAYGATE_WEB_AUTH__DATABASE_USE_ASYNC_ENGINE = "true"
# WAYGATE_WEB_AUTH__AUTO_CREATE_DATABASE = "true"
# WAYGATE_WEB_AUTH__DATABASE_POOL_SIZE = "20"
# WAYGATE_WEB_AUTH__DATABASE_MAX_OVERFLOW = "40"
# WAYGATE_WEB_AUTH__DATABASE_POOL_TIMEOUT = "30"
# WAYGATE_WEB_AUTH__DATABASE_POOL_RECYCLE = "1800"
# WAYGATE_WEB_AUTH__DATABASE_POOL_PRE_PING = "true"

# Session
# WAYGATE_WEB_AUTH__FINGERPRINT_HEADERS = '["User-Agent", "Accept-Language"]'
# WAYGATE_WEB_AUTH__SESSION_DB_VERIFICATION_INTERVAL = "10"
# WAYGATE_WEB_AUTH__SESSION_LIFETIME_SECONDS = "604800"
# WAYGATE_WEB_AUTH__SESSION_ABSOLUTE_LIFETIME_SECONDS = "31536000"
# WAYGATE_WEB_AUTH__SESSION_LIFETIME_FROM = "last_activity"
# WAYGATE_WEB_AUTH__SESSION_SAME_SITE = "LAX"
# WAYGATE_WEB_AUTH__SESSION_TOKEN_NAME = "session_token"
# WAYGATE_WEB_AUTH__SESSION_COOKIE_DOMAIN = ".example.com"
# WAYGATE_WEB_AUTH__LOCK_SESSION_REGION = "true"
# WAYGATE_WEB_AUTH__DISABLE_RANDOM_STRING = "false"
# WAYGATE_WEB_AUTH__RANDOM_STRING_GRACE = "300"

# Email, PII, and token delivery
# WAYGATE_WEB_AUTH__EMAIL_ENABLED = "false"
# WAYGATE_WEB_AUTH__SMTP_HOST = "smtp.example.com"
# WAYGATE_WEB_AUTH__SMTP_PORT = "587"
# WAYGATE_WEB_AUTH__SMTP_USERNAME = "smtp-user"
# WAYGATE_WEB_AUTH__SMTP_PASSWORD = "replace-me"
# WAYGATE_WEB_AUTH__DKIM_PRIVATE_KEY_PATH = "/run/secrets/dkim_private.key"
# WAYGATE_WEB_AUTH__DKIM_DOMAIN = "example.com"
# WAYGATE_WEB_AUTH__DKIM_SELECTOR = "mail"
# WAYGATE_WEB_AUTH__DEFAULT_SENDER_EMAIL = "noreply@example.com"
# WAYGATE_WEB_AUTH__EMAIL_DOMAINS = '["example.com", "example.org"]'
# WAYGATE_WEB_AUTH__PII_ENCRYPTION_ENABLED = "false"
# WAYGATE_WEB_AUTH__PII_HMAC_KEY = "replace-me"
# WAYGATE_WEB_AUTH__ENCRYPT_AUDIT_IP = "true"
# WAYGATE_WEB_AUTH__TOKENS_EXPIRY_SECONDS = "3600"
# WAYGATE_WEB_AUTH__TOKENS_MAX_COUNT_PER_DAY_PER_USER_PER_ACTION = "5"
# WAYGATE_WEB_AUTH__MAIL_STARTTLS = "true"
# WAYGATE_WEB_AUTH__MAIL_SSL_TLS = "false"
# WAYGATE_WEB_AUTH__USE_CREDENTIALS = "true"
# WAYGATE_WEB_AUTH__VALIDATE_CERTS = "true"

# Template locations
# WAYGATE_WEB_AUTH__EMAIL_TEMPLATE_DIR = "/app/templates/email"
# WAYGATE_WEB_AUTH__HTML_TEMPLATE_DIR = "/app/templates/pages"
# WAYGATE_WEB_AUTH__DASHBOARD_AND_USER_INFO_PAGES_TEMPLATE_DIR = "/app/templates/dashboard"

# OAuth
# WAYGATE_WEB_AUTH__GOOGLE_CLIENT_ID = "google-client-id.apps.googleusercontent.com"
# WAYGATE_WEB_AUTH__GOOGLE_CLIENT_SECRET = "replace-me"
# WAYGATE_WEB_AUTH__GOOGLE_REDIRECT_URI = "http://127.0.0.1:8080/auth/google/callback"
# WAYGATE_WEB_AUTH__GITHUB_CLIENT_ID = "github-client-id"
# WAYGATE_WEB_AUTH__GITHUB_CLIENT_SECRET = "replace-me"
# WAYGATE_WEB_AUTH__GITHUB_REDIRECT_URI = "http://127.0.0.1:8080/auth/github/callback"

# RPC
# WAYGATE_WEB_AUTH__RPC_ENABLED = "false"
# WAYGATE_WEB_AUTH__RPC_AUTOSTART = "true"
# WAYGATE_WEB_AUTH__RPC_TOKEN = "replace-me"
# WAYGATE_WEB_AUTH__RPC_TLS_CERT_FILE = "/run/secrets/rpc.crt"
# WAYGATE_WEB_AUTH__RPC_TLS_KEY_FILE = "/run/secrets/rpc.key"
# WAYGATE_WEB_AUTH__RPC_ADDRESS = "[::]:50051"

# WebAuthn
# WAYGATE_WEB_AUTH__WEBAUTHN_ENABLED = "false"
# WAYGATE_WEB_AUTH__WEBAUTHN_RP_ID = "127.0.0.1"
# WAYGATE_WEB_AUTH__WEBAUTHN_RP_NAME = "WayGate"
# WAYGATE_WEB_AUTH__WEBAUTHN_ORIGIN = "http://127.0.0.1:8080"

# Authentication strategy
# WAYGATE_WEB_AUTH__STRATEGY = "AUTO"

# API keys
# WAYGATE_WEB_AUTH__API_KEY_PREFIX_SECRET = "sk"
# WAYGATE_WEB_AUTH__API_KEY_PREFIX_PUBLISHABLE = "pk"
# WAYGATE_WEB_AUTH__API_KEY_PREFIX_MASTER = "mk"
# WAYGATE_WEB_AUTH__API_KEY_PREFIX_OTHER = "key"
# WAYGATE_WEB_AUTH__MAX_MASTER_KEYS_PER_USER = "5"
# WAYGATE_WEB_AUTH__MAX_API_KEYS_PER_USER = "100"
# WAYGATE_WEB_AUTH__MAX_SCOPES_PER_SECRET_KEY = "0"
# WAYGATE_WEB_AUTH__KEY_HASH_ALGORITHM = "SHA384"

# Login rate limiting
# WAYGATE_WEB_AUTH__MAX_LOGIN_ATTEMPTS_PER_IP = "10"
# WAYGATE_WEB_AUTH__MAX_LOGIN_ATTEMPTS_PER_USER = "5"
# WAYGATE_WEB_AUTH__LOGIN_RATE_LIMIT_WINDOW_SECONDS = "900"
# WAYGATE_WEB_AUTH__LOGIN_LOCKOUT_DURATION_SECONDS = "1800"

# Theme
# Nested theme env vars work, but programmatic overrides are safer for large theme changes.
# WAYGATE_WEB_AUTH__THEME__MODE = "system"
# WAYGATE_WEB_AUTH__THEME__LIGHT__BACKGROUND_START = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__LIGHT__BACKGROUND_END = "#FFFFFF"
# WAYGATE_WEB_AUTH__THEME__LIGHT__FOREGROUND = "#020817"
# WAYGATE_WEB_AUTH__THEME__LIGHT__MUTED_FOREGROUND = "#64748B"
# WAYGATE_WEB_AUTH__THEME__LIGHT__CARD = "#FFFFFF"
# WAYGATE_WEB_AUTH__THEME__LIGHT__CARD_FOREGROUND = "#020817"
# WAYGATE_WEB_AUTH__THEME__LIGHT__POPOVER = "#FFFFFF"
# WAYGATE_WEB_AUTH__THEME__LIGHT__POPOVER_FOREGROUND = "#020817"
# WAYGATE_WEB_AUTH__THEME__LIGHT__PRIMARY = "#6D28D9"
# WAYGATE_WEB_AUTH__THEME__LIGHT__PRIMARY_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__LIGHT__SECONDARY = "#F1F5F9"
# WAYGATE_WEB_AUTH__THEME__LIGHT__SECONDARY_FOREGROUND = "#0F172A"
# WAYGATE_WEB_AUTH__THEME__LIGHT__MUTED = "#F1F5F9"
# WAYGATE_WEB_AUTH__THEME__LIGHT__ACCENT = "#F1F5F9"
# WAYGATE_WEB_AUTH__THEME__LIGHT__ACCENT_FOREGROUND = "#0F172A"
# WAYGATE_WEB_AUTH__THEME__LIGHT__DESTRUCTIVE = "#EF4444"
# WAYGATE_WEB_AUTH__THEME__LIGHT__DESTRUCTIVE_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__LIGHT__BORDER = "transparent"
# WAYGATE_WEB_AUTH__THEME__LIGHT__INPUT = "#E2E8F0"
# WAYGATE_WEB_AUTH__THEME__LIGHT__RING = "#94A3B8"
# WAYGATE_WEB_AUTH__THEME__DARK__BACKGROUND_START = "#0B0B0F"
# WAYGATE_WEB_AUTH__THEME__DARK__BACKGROUND_END = "#020817"
# WAYGATE_WEB_AUTH__THEME__DARK__FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__MUTED_FOREGROUND = "#94A3B8"
# WAYGATE_WEB_AUTH__THEME__DARK__CARD = "#777e9145"
# WAYGATE_WEB_AUTH__THEME__DARK__CARD_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__POPOVER = "#020817"
# WAYGATE_WEB_AUTH__THEME__DARK__POPOVER_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__PRIMARY = "#7C3AED"
# WAYGATE_WEB_AUTH__THEME__DARK__PRIMARY_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__SECONDARY = "#6572887d"
# WAYGATE_WEB_AUTH__THEME__DARK__SECONDARY_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__MUTED = "#1E293B"
# WAYGATE_WEB_AUTH__THEME__DARK__ACCENT = "#93b2e6a8"
# WAYGATE_WEB_AUTH__THEME__DARK__ACCENT_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__DESTRUCTIVE = "#7F1D1D"
# WAYGATE_WEB_AUTH__THEME__DARK__DESTRUCTIVE_FOREGROUND = "#F8FAFC"
# WAYGATE_WEB_AUTH__THEME__DARK__BORDER = "transparent"
# WAYGATE_WEB_AUTH__THEME__DARK__INPUT = "#1E293B"
# WAYGATE_WEB_AUTH__THEME__DARK__RING = "#475569"

# Compose-specific host bind mount settings
WIKI_DATA_DIR = "./wiki"

# Core runtime settings for containers
WAYGATE_CORE__STORAGE_PLUGIN_NAME = "local-storage"
WAYGATE_CORE__LLM_PLUGIN_NAME = "OllamaProvider"
WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME = "communication-nats"
WAYGATE_CORE__PG_HOST = "db"
WAYGATE_CORE__PG_PORT = "5432"
WAYGATE_CORE__PG_USER = "postgres"
WAYGATE_CORE__PG_PASSWORD = "postgres"
WAYGATE_CORE__PG_DB = "postgres"
WAYGATE_CORE__REDIS_DSN = "redis://valkey:6379/0"
WAYGATE_CORE__TEMPLATE_PACKAGES = "waygate_core"
WAYGATE_CORE__RAW_DOC_TEMPLATE = "raw_document.j2"
WAYGATE_CORE__COMPILED_DOC_TEMPLATE = "compiled_document.j2"
WAYGATE_CORE__PUBLISHED_DOC_TEMPLATE = "published_document.j2"
WAYGATE_CORE__METADATA_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__DRAFT_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__REVIEW_MODEL_NAME = "hermes3:8b"

# Optional JSON override for per-workflow model and option defaults.
# This value must be valid JSON.
# WAYGATE_CORE__LLM_WORKFLOW_PROFILES = '{"compile":{"model_name":"qwen3.5:9b","provider_options":{"OllamaProvider":{"num_ctx":4096}}}}'

# Backward-compatible aliases still accepted by the runtime.
# WAYGATE_CORE__REDIS_URL = "redis://valkey:6379/0"
# WAYGATE_CORE__RAW_DOCUMENT_TEMPLATE = "raw_document.j2"
# WAYGATE_CORE__COMPILED_DOCUMENT_TEMPLATE = "compiled_document.j2"
# WAYGATE_CORE__PUBLISHED_DOCUMENT_TEMPLATE = "published_document.j2"
# WAYGATE_CORE__METADATA_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__DRAFT_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__REVIEW_MODEL = "hermes3:8b"

# Local storage plugin
WAYGATE_LOCAL_STORAGE__FILE_PREFIX = "file://"
WAYGATE_LOCAL_STORAGE__BASE_PATH = "/data/wiki"
WAYGATE_LOCAL_STORAGE__RAW_DIR = "raw"
WAYGATE_LOCAL_STORAGE__STAGING_DIR = "staging"
WAYGATE_LOCAL_STORAGE__REVIEW_DIR = "review"
WAYGATE_LOCAL_STORAGE__PUBLISH_DIR = "published"
WAYGATE_LOCAL_STORAGE__METADATA_DIR = "metadata"
WAYGATE_LOCAL_STORAGE__TEMPLATES_DIR = "templates"
WAYGATE_LOCAL_STORAGE__AGENTS_DIR = "agents"
WAYGATE_LOCAL_STORAGE__SOFT_DELETE = "false"
WAYGATE_LOCAL_STORAGE__KEEP_VERSIONED = "false"

# communication-rq plugin
# Optional legacy transport. Switch WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME back
# to communication-rq if you need the Redis/RQ worker path.
# In compose.prod.yml, pair that setting with the `rq` profile and omit the
# `nats` profile.
WAYGATE_COMMUNICATION_RQ__REDIS_URL = "redis://valkey:6379/0"
WAYGATE_COMMUNICATION_RQ__DRAFT_QUEUE_NAME = "draft"
WAYGATE_COMMUNICATION_RQ__CRON_QUEUE_NAME = "cron"
WAYGATE_COMMUNICATION_RQ__JOB_FUNCTION = "waygate_worker.rq.process_rq_workflow_trigger"
WAYGATE_COMMUNICATION_RQ__JOB_TIMEOUT = "5m"
WAYGATE_COMMUNICATION_RQ__RESULT_TTL = "500"
WAYGATE_COMMUNICATION_RQ__FAILURE_TTL = "31536000"
WAYGATE_COMMUNICATION_RQ__RETRY_MAX = "3"
WAYGATE_COMMUNICATION_RQ__RETRY_INTERVALS = "[10, 30, 60]"
WAYGATE_COMMUNICATION_RQ__UNIQUE_JOBS = "true"

# communication-http plugin
# Use a container-reachable worker endpoint if you switch
# WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME to communication-http.
# WAYGATE_COMMUNICATION_HTTP__ENDPOINT = "http://worker:8090/workflows/trigger"
WAYGATE_COMMUNICATION_HTTP__TIMEOUT_SECONDS = "5.0"
WAYGATE_COMMUNICATION_HTTP__MAX_RETRIES = "2"
WAYGATE_COMMUNICATION_HTTP__RETRY_BACKOFF_SECONDS = "0.25"
# WAYGATE_COMMUNICATION_HTTP__WORKER_HOST = "0.0.0.0"
# WAYGATE_COMMUNICATION_HTTP__WORKER_PORT = "8090"
# WAYGATE_COMMUNICATION_HTTP__WORKER_ENDPOINT_PATH = "/workflows/trigger"
# WAYGATE_COMMUNICATION_HTTP__AUTH_TOKEN = "replace-me"
WAYGATE_COMMUNICATION_HTTP__AUTH_HEADER = "Authorization"

# communication-nats plugin and worker
# Default Compose transport for durable workflow execution.
# In compose.prod.yml, enable the `nats` profile when this transport is active.
WAYGATE_COMMUNICATION_NATS__SERVERS = "nats://nats:4222"
WAYGATE_COMMUNICATION_NATS__STREAM_NAME = "WAYGATE_WORKFLOW"
WAYGATE_COMMUNICATION_NATS__DRAFT_SUBJECT = "waygate.workflow.draft"
WAYGATE_COMMUNICATION_NATS__CRON_SUBJECT = "waygate.workflow.cron"
WAYGATE_COMMUNICATION_NATS__CLIENT_NAME = "waygate-communication-nats"
WAYGATE_COMMUNICATION_NATS__CONNECT_TIMEOUT_SECONDS = "2.0"
WAYGATE_COMMUNICATION_NATS__PUBLISH_TIMEOUT_SECONDS = "5.0"

WAYGATE_WORKER__SERVERS = "nats://nats:4222"
WAYGATE_WORKER__STREAM_NAME = "WAYGATE_WORKFLOW"
WAYGATE_WORKER__DRAFT_SUBJECT = "waygate.workflow.draft"
WAYGATE_WORKER__CRON_SUBJECT = "waygate.workflow.cron"
WAYGATE_WORKER__DRAFT_CONSUMER_NAME = "waygate-draft"
WAYGATE_WORKER__CRON_CONSUMER_NAME = "waygate-cron"
WAYGATE_WORKER__CLIENT_NAME = "waygate-worker"
WAYGATE_WORKER__ACK_WAIT_SECONDS = "30.0"
WAYGATE_WORKER__IN_PROGRESS_HEARTBEAT_SECONDS = "15.0"
WAYGATE_WORKER__MAX_DELIVER = "3"
WAYGATE_WORKER__BACKOFF_SECONDS = "[10, 30, 60]"

# Ollama provider plugin
# Enable the `ollama` profile in compose.prod.yml when this points at the local
# Compose service. Otherwise, set BASE_URL to your external Ollama-compatible
# endpoint and omit the profile.
WAYGATE_OLLAMAPROVIDER__BASE_URL = "http://ollama:11434"
WAYGATE_OLLAMAPROVIDER__VALIDATE_MODEL_ON_INIT = "true"

# Featherless AI provider plugin
# Uncomment these and switch WAYGATE_CORE__LLM_PLUGIN_NAME when using Featherless AI.
# WAYGATE_CORE__LLM_PLUGIN_NAME = "FeatherlessAIProvider"
# WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_API_KEY = "your-featherless-api-key"
WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_BASE_URL = "https://api.featherless.ai/v1"

# agent-session webhook plugin
# Provide a signing secret in production. For local-only unsigned testing, set
# ALLOW_UNSIGNED to true and leave SIGNING_SECRET commented out.
# WAYGATE_AGENT_SESSION__SIGNING_SECRET = "replace-me"
WAYGATE_AGENT_SESSION__ALLOW_UNSIGNED = "false"
WAYGATE_AGENT_SESSION__MAX_TIMESTAMP_SKEW_SECONDS = "300"

# Compose service image and port settings
POSTGRES_VERSION = "18"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "postgres"
POSTGRES_DB = "postgres"
PGDATA = "/var/lib/postgresql/data"
POSTGRES_PORT = "5432"

VALKEY_VERSION = "9"
VALKEY_PORT = "6379"

CHROMA_VERSION = "1.5.8"
CHROMA_PORT = "8000"
CHROMA_PERSIST_DIRECTORY = "/chroma/chroma"
CHROMA_TELEMETRY = "FALSE"

OLLAMA_VERSION = "0.21.0"
OLLAMA_PORT = "11434"
OLLAMA_KEEP_ALIVE = "5m"
OLLAMA_FLASH_ATTENTION = "1"
OLLAMA_KV_CACHE_TYPE = "q8_0"
GPU_DRIVER = "nvidia"
GPU_COUNT = "all"

NATS_VERSION = "2-alpine"
NATS_CLIENT_PORT = "4222"
NATS_MONITORING_PORT = "8222"
NATS_CLUSTER_PORT = "6222"
