# Copy this file to .env for local development or non-Compose deployment.

# Application process settings
HOST = "0.0.0.0"
PORT = "8080"
LOG_LEVEL = "INFO"

# Core runtime settings
WAYGATE_CORE__STORAGE_PLUGIN_NAME = "local-storage"
WAYGATE_CORE__LLM_PLUGIN_NAME = "OllamaProvider"
WAYGATE_CORE__COMMUNICATION_PLUGIN_NAME = "communication-rq"
WAYGATE_CORE__PG_HOST = "localhost"
WAYGATE_CORE__PG_PORT = "5432"
WAYGATE_CORE__PG_USER = "postgres"
WAYGATE_CORE__PG_PASSWORD = "postgres"
WAYGATE_CORE__PG_DB = "postgres"
WAYGATE_CORE__REDIS_DSN = "redis://localhost:6379/0"
WAYGATE_CORE__TEMPLATE_PACKAGES = "waygate_core"
WAYGATE_CORE__RAW_DOC_TEMPLATE = "raw_document.j2"
WAYGATE_CORE__DRAFT_DOC_TEMPLATE = "draft_source_text.j2"
WAYGATE_CORE__METADATA_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__DRAFT_MODEL_NAME = "qwen3.5:9b"
WAYGATE_CORE__REVIEW_MODEL_NAME = "hermes3:8b"

# Optional JSON override for per-workflow model and option defaults.
# This value must be valid JSON.
# WAYGATE_CORE__LLM_WORKFLOW_PROFILES = '{"draft":{"model_name":"qwen3.5:9b","common_options":{"temperature":0.2}}}'

# Backward-compatible aliases still accepted by the runtime.
# WAYGATE_CORE__REDIS_URL = "redis://localhost:6379/0"
# WAYGATE_CORE__RAW_DOCUMENT_TEMPLATE = "raw_document.j2"
# WAYGATE_CORE__DRAFT_DOCUMENT_TEMPLATE = "draft_source_text.j2"
# WAYGATE_CORE__METADATA_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__DRAFT_MODEL = "qwen3.5:9b"
# WAYGATE_CORE__REVIEW_MODEL = "hermes3:8b"

# Local storage plugin
WAYGATE_LOCAL_STORAGE__FILE_PREFIX = "file://"
WAYGATE_LOCAL_STORAGE__BASE_PATH = "wiki"
WAYGATE_LOCAL_STORAGE__RAW_DIR = "raw"
WAYGATE_LOCAL_STORAGE__STAGING_DIR = "staging"
WAYGATE_LOCAL_STORAGE__REVIEW_DIR = "review"
WAYGATE_LOCAL_STORAGE__PUBLISH_DIR = "published"
WAYGATE_LOCAL_STORAGE__METADATA_DIR = "metadata"
WAYGATE_LOCAL_STORAGE__TEMPLATES_DIR = "templates"
WAYGATE_LOCAL_STORAGE__AGENTS_DIR = "agents"
WAYGATE_LOCAL_STORAGE__SOFT_DELETE = "false"
WAYGATE_LOCAL_STORAGE__KEEP_VERSIONED = "false"

# communication-rq plugin
WAYGATE_COMMUNICATION_RQ__REDIS_URL = "redis://localhost:6379/0"
WAYGATE_COMMUNICATION_RQ__DRAFT_QUEUE_NAME = "draft"
WAYGATE_COMMUNICATION_RQ__CRON_QUEUE_NAME = "cron"
WAYGATE_COMMUNICATION_RQ__JOB_FUNCTION = "waygate_workflows.draft.jobs.process_workflow_trigger"
WAYGATE_COMMUNICATION_RQ__JOB_TIMEOUT = "5m"
WAYGATE_COMMUNICATION_RQ__RESULT_TTL = "500"
WAYGATE_COMMUNICATION_RQ__FAILURE_TTL = "31536000"
WAYGATE_COMMUNICATION_RQ__RETRY_MAX = "3"
WAYGATE_COMMUNICATION_RQ__RETRY_INTERVALS = "[10, 30, 60]"
WAYGATE_COMMUNICATION_RQ__UNIQUE_JOBS = "true"

# communication-http plugin
WAYGATE_COMMUNICATION_HTTP__ENDPOINT = "http://localhost:8090/workflows/trigger"
WAYGATE_COMMUNICATION_HTTP__TIMEOUT_SECONDS = "5.0"
WAYGATE_COMMUNICATION_HTTP__MAX_RETRIES = "2"
WAYGATE_COMMUNICATION_HTTP__RETRY_BACKOFF_SECONDS = "0.25"
# WAYGATE_COMMUNICATION_HTTP__AUTH_TOKEN = "replace-me"
WAYGATE_COMMUNICATION_HTTP__AUTH_HEADER = "Authorization"

# Ollama provider plugin
WAYGATE_OLLAMAPROVIDER__BASE_URL = "http://localhost:11434"
WAYGATE_OLLAMAPROVIDER__VALIDATE_MODEL_ON_INIT = "true"

# Featherless AI provider plugin
# Uncomment these and switch WAYGATE_CORE__LLM_PLUGIN_NAME when using Featherless AI.
# WAYGATE_CORE__LLM_PLUGIN_NAME = "FeatherlessAIProvider"
# WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_API_KEY = "your-featherless-api-key"
WAYGATE_FEATHERLESSAIPROVIDER__FEATHERLESS_BASE_URL = "https://api.featherless.ai/v1"

# agent-session webhook plugin
# Provide a signing secret in production. For local-only unsigned testing, set
# ALLOW_UNSIGNED to true and leave SIGNING_SECRET commented out.
# WAYGATE_AGENT_SESSION__SIGNING_SECRET = "replace-me"
WAYGATE_AGENT_SESSION__ALLOW_UNSIGNED = "false"
WAYGATE_AGENT_SESSION__MAX_TIMESTAMP_SKEW_SECONDS = "300"
